# Frontend (Vite) — optional for local testing
# Use the same value as RSVP_SECRET on the server when set
VITE_RSVP_SECRET=
# Override API URL only if needed (default: /api/rsvp)
# VITE_RSVP_API_URL=http://localhost:3000/api/rsvp

# Server (Vercel → Project Settings → Environment Variables)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=RSVP
RSVP_SECRET=
